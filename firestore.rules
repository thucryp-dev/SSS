rules_version = '2';

/**
 * firestore.rules — v1.12
 *
 * Anonymous Auth scoped (one uid per device, no login screen).
 * Every document carries ownerId = request.auth.uid.
 *
 * KEY SPLIT:
 *   lessons: allow get = open (shareable links work for anyone with the URL)
 *            allow list = owner-only (history page only shows your lessons)
 *   pendingLessons: fully owner-scoped (no sharing use case)
 */

service cloud.firestore {
  match /databases/{database}/documents {

    function isValidAgeGroup(v) {
      return v in ['5-7', '8-10', '11-12', 'adult'];
    }

    function isValidSections(s) {
      return s is map
        && s.keys().hasAll(['story', 'quiz', 'image'])
        && s.story is bool
        && s.quiz  is bool
        && s.image is bool;
    }

    function isValidPendingLesson(data) {
      return data.keys().hasAll(['inputText', 'createdAt', 'status', 'ownerId', 'ageGroup'])
        && data.inputText is string
        && data.inputText.size() > 0
        && data.inputText.size() <= 2000
        && data.createdAt is int
        && data.status == 'pending'
        && data.ownerId is string
        && isValidAgeGroup(data.ageGroup);
    }

    function isValidLesson(data) {
      return data.keys().hasAll([
          'title', 'bible_verse', 'story_slides',
          'quiz_questions', 'inputText', 'createdAt', 'ownerId'
        ])
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 200
        && data.bible_verse is string
        && data.story_slides is list
        && data.story_slides.size() <= 12
        && data.quiz_questions is list
        && data.quiz_questions.size() <= 12
        && data.inputText is string
        && data.inputText.size() <= 2000
        && data.createdAt is int
        && data.ownerId is string;
    }

    match /pendingLessons/{requestId} {
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && isValidPendingLesson(request.resource.data);
      allow get, list, delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;
      allow update: if false;
    }

    match /lessons/{lessonId} {
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && isValidLesson(request.resource.data);
      // Open single-doc read — powers shareable /lesson/[id] links
      allow get: if true;
      // Owner-only list — powers the history page
      allow list: if request.auth != null
        && request.auth.uid == resource.data.ownerId;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
